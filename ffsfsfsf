ScanActionBtn.MouseButton1Click:Connect(function()
    if IsScanning then return end
    IsScanning = true
    TargetRemote = nil
    ScanActionBtn.Text = "SCANNING..."
    RemoteMap = {}
    local remotes = {}
    local susServices = {game.ReplicatedStorage, game.JointsService, game.Lighting, game.SoundService, game.Workspace}
    for _, s in ipairs(susServices) do 
        for _, v in ipairs(s:GetDescendants()) do 
            if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then table.insert(remotes, v) end 
        end 
    end

    task.spawn(function()
        for i, r in ipairs(remotes) do
            if not IsScanning then break end
            pcall(function()
                local uniqueId = tostring(i)
                RemoteMap[uniqueId] = r
                local p = string.format(TestCode, uniqueId)
                if r:IsA("RemoteEvent") then 
                    r:FireServer(p) 
                else 
                    task.spawn(function() r:InvokeServer(p) end) 
                end
            end)
            if i % 40 == 0 then RunService.Heartbeat:Wait() end
        end
    end)
end)

